{
  "manifest_version": 3,
  "version": "2.3.1",
  "name": "Lark Project Linker",
  "description": "连接 GitLab/GitHub/Sentry 与飞书项目。自动转换项目 ID 为可点击链接，支持智能类型识别和一键创建飞书工单",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["index.js"]
    },
    {
      "matches": ["*://*/*"],
      "js": ["sentry.js"]
    }
  ],
  "options_page": "options.html"
}
