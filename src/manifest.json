{
  "manifest_version": 3,
  "version": "2.2.1",
  "name": "GitLab Link to Lark",
  "description": "将 GitLab 项目 ID 转换为飞书链接，支持 Sentry Issue 一键创建飞书工单",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["index.js"]
    },
    {
      "matches": ["*://*/*"],
      "js": ["sentry.js"]
    }
  ],
  "options_page": "options.html"
}
